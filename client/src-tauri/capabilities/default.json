{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-exists",
    "fs:allow-read-dir",
    "fs:allow-watch",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:scope-home",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "/storage/emulated/0/**" },
        { "path": "/sdcard/**" }
      ]
    },
    "dialog:default",
    "dialog:allow-open",
    "opener:default",
    "opener:allow-reveal-item-in-dir"
  ]
}
